    "knex": "^3.1.0",
    "better-sqlite3": "^11.3.0",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
